PORT=4100
HOST=0.0.0.0
NODE_ENV=development

# Comma-separated origins allowed to connect from browsers.
CORS_ORIGIN=http://localhost,http://127.0.0.1,http://localhost:80,http://127.0.0.1:80,http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173

# Required for Laravel/server-to-server event publish calls.
INTERNAL_API_KEY=change-this-in-production

# Used to verify browser socket auth tokens.
SOCKET_AUTH_SECRET=change-this-signing-secret

# Publish endpoint rate limit per IP.
PUBLISH_RATE_LIMIT=120
PUBLISH_RATE_WINDOW_MS=60000

# Keep browser sockets alive across short mobile/network stalls or busy dashboard loads.
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=60000

# Development only. Set false in staging/production.
ALLOW_UNSIGNED_AUTH=true

# Production checklist values:
# NODE_ENV=production
# CORS_ORIGIN=https://your-domain.example
# INTERNAL_API_KEY=use-a-long-random-secret
# SOCKET_AUTH_SECRET=use-a-different-long-random-secret
# ALLOW_UNSIGNED_AUTH=false
