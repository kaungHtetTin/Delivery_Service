APP_NAME="FlowDrop Delivery"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=delivery_app
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SOCKET_SERVER_ENABLED=true
SOCKET_SERVER_URL=http://127.0.0.1:4100
SOCKET_SERVER_KEY=change-this-in-production
SOCKET_AUTH_SECRET=change-this-signing-secret
SOCKET_AUTH_TOKEN_TTL=3600
SOCKET_SERVER_TIMEOUT=2
RIDER_LOCATION_RETENTION_DAYS=14

MAP_TILE_CACHE_ENABLED=true
MAP_TILE_CACHE_DISK=local
MAP_TILE_CACHE_PATH=map-tiles
MAP_TILE_CACHE_MAX_GB=10
MAP_TILE_MIN_ZOOM=0
MAP_TILE_MAX_ZOOM=19
MAP_TILE_PROVIDER_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_PROVIDER_USER_AGENT="${APP_NAME} tile cache"
MAP_TILE_PROVIDER_TIMEOUT=8

VITE_SOCKET_URL=http://127.0.0.1:4100
VITE_SOCKET_ENABLED=true
